{
  "name": "@persistlyapp/sdk",
  "version": "0.11.3",
  "description": "JavaScript SDK for Persistly cloud save sync.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "homepage": "https://docs.persistly.app/sdk/javascript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Persistly/persistly-sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/Persistly/persistly-sdk-js/issues"
  },
  "keywords": [
    "persistly",
    "game saves",
    "cloud saves",
    "save sync",
    "games"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./account": {
      "types": "./dist/account.d.ts",
      "default": "./dist/account.js"
    },
    "./autosave": {
      "types": "./dist/autosave.d.ts",
      "default": "./dist/autosave.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./game-saves": {
      "types": "./dist/game-saves.d.ts",
      "default": "./dist/game-saves.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "contracts",
    "templates"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"tests/*.test.ts\"",
    "test:package": "pnpm build && node scripts/package-consumer-smoke.mjs",
    "validate:contract": "node scripts/validate-contract.mjs",
    "prepack": "pnpm validate:contract && pnpm test && pnpm build && node scripts/package-consumer-smoke.mjs",
    "example:basic": "tsx examples/basic.ts",
    "example:conflict": "tsx examples/conflict.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
